<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Job Radar Digest — {{ date }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 700px; margin: 0 auto; padding: 24px; color: #1a1a1a; }
  h1 { color: #2563eb; border-bottom: 2px solid #e5e7eb; padding-bottom: 12px; }
  .meta { color: #6b7280; font-size: 0.9em; margin-bottom: 24px; }
  .job { border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; margin-bottom: 16px; }
  .job-header { display: flex; justify-content: space-between; align-items: flex-start; }
  .job-title { font-size: 1.1em; font-weight: 600; margin: 0; }
  .job-company { color: #6b7280; margin: 4px 0 12px; }
  .score { background: #2563eb; color: white; border-radius: 20px; padding: 4px 12px; font-weight: 700; white-space: nowrap; }
  .score.high { background: #16a34a; }
  .score.mid { background: #d97706; }
  .pill { display: inline-block; background: #eff6ff; color: #1d4ed8; border-radius: 4px; padding: 2px 8px; font-size: 0.8em; margin: 2px; }
  .verdict { background: #f0fdf4; border-left: 3px solid #16a34a; padding: 8px 12px; margin: 12px 0; font-style: italic; }
  .pitch { background: #fef9c3; border-left: 3px solid #ca8a04; padding: 8px 12px; margin: 12px 0; }
  .gaps { background: #fff7ed; border-left: 3px solid #ea580c; padding: 8px 12px; margin: 12px 0; }
  .apply-btn { display: inline-block; background: #2563eb; color: white; text-decoration: none; padding: 8px 16px; border-radius: 6px; font-size: 0.9em; margin-top: 12px; }
  .rank { color: #9ca3af; font-size: 0.85em; margin-bottom: 4px; }
  footer { color: #9ca3af; font-size: 0.8em; text-align: center; margin-top: 32px; }
</style>
</head>
<body>
<h1>🎯 Job Radar Digest</h1>
<p class="meta">{{ date }} · {{ total_scored }} jobs scored · {{ total_passed }} passed filters · showing top {{ jobs | length }}</p>

{% for job in jobs %}
<div class="job">
  <div class="rank">#{{ loop.index }}</div>
  <div class="job-header">
    <div>
      <p class="job-title">{{ job.posting.title }}</p>
      <p class="job-company">{{ job.posting.company }} · {{ job.posting.location }} · {{ job.posting.source }}</p>
    </div>
    <span class="score {% if job.score >= 70 %}high{% elif job.score >= 50 %}mid{% endif %}">{{ job.score }}/100</span>
  </div>

  {% if job.breakdown.matched_skills %}
  <div>
    {% for skill in job.breakdown.matched_skills %}
    <span class="pill">{{ skill }}</span>
    {% endfor %}
  </div>
  {% endif %}

  {% if job.llm_verdict %}
  <div class="verdict"><strong>Verdict:</strong> {{ job.llm_verdict }}</div>
  {% endif %}

  {% if job.llm_pitch %}
  <div class="pitch"><strong>Cold opener:</strong><br>{{ job.llm_pitch }}</div>
  {% endif %}

  {% if job.llm_resume_emphasis %}
  <p><strong>Lead with:</strong> {{ job.llm_resume_emphasis }}</p>
  {% endif %}

  {% if job.llm_gaps %}
  <div class="gaps"><strong>Gaps to address:</strong> {{ job.llm_gaps | join(", ") }}</div>
  {% endif %}

  <a class="apply-btn" href="{{ job.posting.url }}" target="_blank">View Job →</a>
</div>
{% endfor %}

<footer>Generated by <a href="https://github.com/venkateshjnv123/job-radar">job-radar</a></footer>
</body>
</html>
